{
  "name": "kinx-auto",
  "version": "4.5.1",
  "main": "dist-electron/main.js",
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "@google/genai": "^1.13.0",
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.17.0",
    "body-parser": "^2.2.2",
    "dotenv": "^16.4.5",
    "edge-tts-node": "^1.5.7",
    "electron-updater": "^6.1.1",
    "express": "^5.2.1",
    "fluent-ffmpeg": "^2.1.3",
    "gtts": "^0.2.1",
    "http-proxy-agent": "^9.0.0",
    "https-proxy-agent": "^7.0.6",
    "i18next": "^25.6.0",
    "lucide-react": "^0.546.0",
    "node-fetch": "^2.7.0",
    "proxy-chain": "^2.7.1",
    "puppeteer": "^24.22.0",
    "puppeteer-core": "^24.43.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^16.1.0",
    "react-resizable-panels": "^3.0.6",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "socks-proxy-agent": "^10.0.0",
    "sweetalert2": "^11.26.24"
  },
  "description": "Kinx Auto ",
  "devDependencies": {
    "electron": "^38.1.2",
    "electron-builder": "^26.0.12",
    "vite": "^8.0.16"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win --publish never",
    "dist:portable": "electron-builder --win portable --publish never",
    "dist:nsis": "electron-builder --win nsis --publish never",
    "dist:mac": "electron-builder --mac --publish never"
  },
  "build": {
    "appId": "com.kinxauto.app",
    "productName": "Kinx Auto",
    "artifactName": "Kinx.Auto.Setup.${version}.${ext}",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "extraFiles": [
        {
          "from": "build/ffmpeg",
          "to": ".",
          "filter": [
            "*.exe"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Kinx Auto"
    },
    "publish": {
      "provider": "github",
      "owner": "KinX-ai",
      "repo": "H2Book"
    },
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "identity": null,
      "extraFiles": [
        {
          "from": "build/ffmpeg",
          "to": ".",
          "filter": [
            "*",
            "!*.exe"
          ]
        }
      ]
    }
  },
  "keywords": [],
  "author": "Kinx Auto",
  "license": "ISC",
  "type": "commonjs",
  "mac": {
    "target": [
      {
        "target": "dmg",
        "arch": [
          "x64",
          "arm64"
        ]
      },
      {
        "target": "zip",
        "arch": [
          "x64",
          "arm64"
        ]
      }
    ],
    "identity": null
  }
}